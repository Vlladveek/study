{
  "compilerOptions": {
    /* Базовые настройки */
    "target": "ES2022",           // В какую версию JS компилировать (ES6, ES2022 и т.д.)
    "module": "NodeNext",        // Система модулей (CommonJS или современные ES-модули)
    "moduleResolution": "NodeNext", // Как TS ищет импортируемые файлы
    "lib": ["ES2022", "DOM"],    // Какие библиотеки типов доступны (например, DOM для браузера)
    
    /* Пути и файлы */
    "rootDir": "./src",          // Где лежат ваши исходные .ts файлы
    "outDir": "./dist",         // Куда складывать готовые .js файлы
    "sourceMap": true,           // Создавать карты кода для удобной отладки в браузере/IDE
    
    /* Строгость и безопасность */
    "strict": true,              // Включает все проверки типов (лучшая практика)
    "noImplicitAny": true,       // Запрещает переменные без указания типа (any)
    "esModuleInterop": true,     // Позволяет импортировать CommonJS модули как обычные
    "skipLibCheck": true         // Пропускать проверку типов во внешних библиотеках (ускоряет сборку)
  },
  "include": ["src/**/*"],       // Какие файлы включать в компиляцию
  "exclude": ["node_modules"]    // Что игнорировать
}
